  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#8E7C5A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#9C7A40"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#4A3D2A"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#9C7A40"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#4A6B38"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#7A5F2E"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#A5602B"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "variable.language"
      ],
      "settings": {
        "foreground": "#6E5890"
      }
    },
    {
      "scope": [
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#A5602B"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#1F1810"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.class",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#4C5A90"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#2B2117"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#4A3D2A"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#4A3D2A"
      }
    },
    {
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#7A5F2E"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#A5602B"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#6E5E42"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#7A5F2E",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#1F1810",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#2B2117",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#4A6B38"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#6E5E42",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "constant.other.reference.link"
      ],
      "settings": {
        "foreground": "#7A5F2E",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "punctuation.definition.inserted"
      ],
      "settings": {
        "foreground": "#4A6B38"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "punctuation.definition.deleted"
      ],
      "settings": {
        "foreground": "#A8352B"
      }
    },
    {
      "scope": [
        "markup.changed",
        "punctuation.definition.changed"
      ],
      "settings": {
        "foreground": "#A5602B"
      }
    },
    {
      "scope": [
        "meta.diff.header",
        "punctuation.definition.from-file",
        "punctuation.definition.to-file"
      ],
      "settings": {
        "foreground": "#6E5890"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal",
        "message.error"
      ],
      "settings": {
        "foreground": "#A8352B"
      }
    },
    {
      "scope": [
        "token.info-token"
      ],
      "settings": {
        "foreground": "#7A5F2E"
      }
    },
    {
      "scope": [
        "token.warn-token"
      ],
      "settings": {
        "foreground": "#A5602B"
      }
    },
    {
      "scope": [
        "token.error-token"
      ],
      "settings": {
        "foreground": "#A8352B"
      }
    },
    {
      "scope": [
        "token.debug-token"
      ],
      "settings": {
        "foreground": "#6E5890"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#4A3D2A",
    "property": "#4A3D2A",
    "variable": "#2B2117",
    "variable.readonly": "#6E5890",
    "function": "#1F1810",
    "method": "#1F1810",
    "class": "#4C5A90",
    "type": "#4C5A90",
    "enum": "#4C5A90",
    "interface": "#4C5A90",
    "struct": "#4C5A90",
    "typeParameter": "#4C5A90",
    "namespace": "#4A3D2A",
    "keyword": "#9C7A40",
    "string": "#4A6B38",
    "number": "#A5602B",
    "enumMember": "#A5602B",
    "macro": "#6E5890",
    "decorator": "#A5602B",
    "comment": {
      "foreground": "#8E7C5A",
      "fontStyle": "italic"
    },
    "*.deprecated": {
      "fontStyle": "strikethrough"
    }
  }
}

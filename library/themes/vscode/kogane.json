    "terminal.ansiBrightWhite": "#F7EED2"
  },
  "tokenColors": [
    {
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6B5F49",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "keyword",
        "storage",
        "storage.type",
        "storage.modifier",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#D6AE66"
      }
    },
    {
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#C9BC96"
      }
    },
    {
      "scope": [
        "entity.name.tag",
        "entity.name.tag.html"
      ],
      "settings": {
        "foreground": "#D6AE66"
      }
    },
    {
      "scope": [
        "string",
        "string.quoted",
        "string.template"
      ],
      "settings": {
        "foreground": "#8FAC6F"
      }
    },
    {
      "scope": [
        "constant.character.escape",
        "punctuation.definition.template-expression"
      ],
      "settings": {
        "foreground": "#D6AE66"
      }
    },
    {
      "scope": [
        "constant.numeric",
        "constant.numeric.integer",
        "constant.numeric.float"
      ],
      "settings": {
        "foreground": "#C67F45"
      }
    },
    {
      "scope": [
        "constant.language",
        "constant.language.boolean",
        "variable.language"
      ],
      "settings": {
        "foreground": "#9C7FB0"
      }
    },
    {
      "scope": [
        "constant.other",
        "support.constant"
      ],
      "settings": {
        "foreground": "#C67F45"
      }
    },
    {
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call.generic"
      ],
      "settings": {
        "foreground": "#F7EED2"
      }
    },
    {
      "scope": [
        "entity.name.type",
        "support.type",
        "entity.name.class",
        "support.class",
        "entity.other.inherited-class"
      ],
      "settings": {
        "foreground": "#7C88B8"
      }
    },
    {
      "scope": [
        "variable",
        "meta.definition.variable.name",
        "support.variable"
      ],
      "settings": {
        "foreground": "#EDE3C4"
      }
    },
    {
      "scope": [
        "variable.parameter",
        "meta.parameter"
      ],
      "settings": {
        "foreground": "#C9BC96"
      }
    },
    {
      "scope": [
        "variable.other.property",
        "support.variable.property",
        "meta.object-literal.key"
      ],
      "settings": {
        "foreground": "#C9BC96"
      }
    },
    {
      "scope": [
        "support.type.property-name.json",
        "support.type.property-name"
      ],
      "settings": {
        "foreground": "#D6AE66"
      }
    },
    {
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#C67F45"
      }
    },
    {
      "scope": [
        "punctuation",
        "meta.brace",
        "punctuation.separator",
        "punctuation.terminator"
      ],
      "settings": {
        "foreground": "#94866A"
      }
    },
    {
      "scope": [
        "markup.heading",
        "markup.heading entity.name",
        "entity.name.section"
      ],
      "settings": {
        "foreground": "#D6AE66",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.bold"
      ],
      "settings": {
        "foreground": "#F7EED2",
        "fontStyle": "bold"
      }
    },
    {
      "scope": [
        "markup.italic"
      ],
      "settings": {
        "foreground": "#EDE3C4",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.inline.raw",
        "markup.fenced_code",
        "markup.raw"
      ],
      "settings": {
        "foreground": "#8FAC6F"
      }
    },
    {
      "scope": [
        "markup.quote"
      ],
      "settings": {
        "foreground": "#94866A",
        "fontStyle": "italic"
      }
    },
    {
      "scope": [
        "markup.underline.link",
        "string.other.link",
        "constant.other.reference.link"
      ],
      "settings": {
        "foreground": "#D6AE66",
        "fontStyle": "underline"
      }
    },
    {
      "scope": [
        "markup.inserted",
        "punctuation.definition.inserted"
      ],
      "settings": {
        "foreground": "#8FAC6F"
      }
    },
    {
      "scope": [
        "markup.deleted",
        "punctuation.definition.deleted"
      ],
      "settings": {
        "foreground": "#D4665C"
      }
    },
    {
      "scope": [
        "markup.changed",
        "punctuation.definition.changed"
      ],
      "settings": {
        "foreground": "#C67F45"
      }
    },
    {
      "scope": [
        "meta.diff.header",
        "punctuation.definition.from-file",
        "punctuation.definition.to-file"
      ],
      "settings": {
        "foreground": "#9C7FB0"
      }
    },
    {
      "scope": [
        "invalid",
        "invalid.illegal",
        "message.error"
      ],
      "settings": {
        "foreground": "#D4665C"
      }
    },
    {
      "scope": [
        "token.info-token"
      ],
      "settings": {
        "foreground": "#D6AE66"
      }
    },
    {
      "scope": [
        "token.warn-token"
      ],
      "settings": {
        "foreground": "#C67F45"
      }
    },
    {
      "scope": [
        "token.error-token"
      ],
      "settings": {
        "foreground": "#D4665C"
      }
    },
    {
      "scope": [
        "token.debug-token"
      ],
      "settings": {
        "foreground": "#9C7FB0"
      }
    }
  ],
  "semanticTokenColors": {
    "parameter": "#C9BC96",
    "property": "#C9BC96",
    "variable": "#EDE3C4",
    "variable.readonly": "#9C7FB0",
    "function": "#F7EED2",
    "method": "#F7EED2",
    "class": "#7C88B8",
    "type": "#7C88B8",
    "enum": "#7C88B8",
    "interface": "#7C88B8",
    "struct": "#7C88B8",
    "typeParameter": "#7C88B8",
    "namespace": "#C9BC96",
    "keyword": "#D6AE66",
    "string": "#8FAC6F",
    "number": "#C67F45",
    "enumMember": "#C67F45",
    "macro": "#9C7FB0",
    "decorator": "#C67F45",
    "comment": {
      "foreground": "#6B5F49",
      "fontStyle": "italic"
    },
    "*.deprecated": {
      "fontStyle": "strikethrough"
    }
  }
}
